{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wiredchaos.example/schemas/54t/receipt.schema.json",
  "title": "AGENTROPOLIS-54T Privileged Action Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "receipt_id", "request_id", "timestamp", "environment", "data_classification", "actor_id", "actor_type", "action", "action_class", "risk_level", "autonomy_tier", "policy_id", "policy_version", "policy_gate", "decision", "approval_status", "input_hash", "nonce", "signing"],
  "properties": {
    "schema_version": {"type": "string", "const": "0.1.0"},
    "receipt_id": {"type": "string", "minLength": 8, "maxLength": 128, "pattern": "^[A-Za-z0-9._:-]+$"},
    "request_id": {"type": "string", "minLength": 8, "maxLength": 128},
    "workflow_id": {"type": ["string", "null"], "maxLength": 128},
    "timestamp": {"type": "string", "format": "date-time"},
    "environment": {"enum": ["local", "development", "staging", "production", "offline"]},
    "jurisdiction": {"type": ["string", "null"], "maxLength": 64},
    "data_classification": {"enum": ["public", "internal", "confidential", "restricted"]},
    "actor_id": {"type": "string", "minLength": 3, "maxLength": 128},
    "actor_type": {"enum": ["human", "agent", "service", "system"]},
    "agent_id": {"type": ["string", "null"], "maxLength": 128},
    "agent_version": {"type": ["string", "null"], "maxLength": 64},
    "tool_id": {"type": ["string", "null"], "maxLength": 128},
    "tool_version": {"type": ["string", "null"], "maxLength": 64},
    "action": {"type": "string", "minLength": 3, "maxLength": 160},
    "action_class": {"enum": ["read", "recommendation", "tool_execution", "privileged_action", "wallet", "settlement", "policy_change"]},
    "risk_level": {"enum": ["low", "medium", "high", "critical"]},
    "autonomy_tier": {"enum": ["A0", "A1", "A2", "A3", "A4", "A5"]},
    "policy_id": {"type": "string", "minLength": 3, "maxLength": 80},
    "policy_version": {"type": "string", "minLength": 3, "maxLength": 32},
    "policy_gate": {"type": "string", "minLength": 3, "maxLength": 80},
    "decision": {"enum": ["allow", "deny", "quarantine", "require_approval", "error"]},
    "decision_reason": {"type": ["string", "null"], "maxLength": 400},
    "approval_status": {"enum": ["not_required", "pending", "approved", "denied", "expired"]},
    "approval_evidence": {"type": ["array", "null"], "maxItems": 10, "items": {"$ref": "#/$defs/approvalEvidence"}},
    "wallet_details": {"$ref": "#/$defs/walletDetails"},
    "input_hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "output_hash": {"type": ["string", "null"], "pattern": "^sha256:[a-f0-9]{64}$"},
    "previous_receipt_hash": {"type": ["string", "null"], "pattern": "^sha256:[a-f0-9]{64}$"},
    "nonce": {"type": "string", "minLength": 8, "maxLength": 128},
    "expires_at": {"type": ["string", "null"], "format": "date-time"},
    "error": {"$ref": "#/$defs/error"},
    "signing": {"$ref": "#/$defs/signing"},
    "metadata": {"type": "object", "additionalProperties": {"type": ["string", "number", "boolean", "null"]}, "maxProperties": 20},
    "notes": {"type": ["string", "null"], "maxLength": 500}
  },
  "allOf": [
    {"if": {"properties": {"approval_status": {"const": "approved"}}, "required": ["approval_status"]}, "then": {"required": ["approval_evidence"]}},
    {"if": {"properties": {"decision": {"const": "error"}}, "required": ["decision"]}, "then": {"required": ["error"]}},
    {"if": {"properties": {"action_class": {"enum": ["wallet", "settlement"]}}, "required": ["action_class"]}, "then": {"required": ["wallet_details"]}}
  ],
  "$defs": {
    "approvalEvidence": {"type": "object", "additionalProperties": false, "required": ["approver_id", "approver_type", "timestamp", "expires_at", "normalized_payload_hash", "evidence_ref"], "properties": {"approver_id": {"type": "string", "minLength": 3, "maxLength": 128}, "approver_type": {"enum": ["human", "agent", "service", "system"]}, "timestamp": {"type": "string", "format": "date-time"}, "expires_at": {"type": "string", "format": "date-time"}, "normalized_payload_hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"}, "evidence_ref": {"type": "string", "minLength": 3, "maxLength": 200}, "signature": {"type": ["string", "null"], "maxLength": 256}}},
    "walletDetails": {"type": "object", "additionalProperties": false, "required": ["initiator_id", "chain", "asset", "amount", "destination", "normalized_transaction_hash", "replay_nonce"], "properties": {"initiator_id": {"type": "string", "minLength": 3, "maxLength": 128}, "chain": {"type": "string", "minLength": 2, "maxLength": 64}, "asset": {"type": "string", "minLength": 2, "maxLength": 32}, "amount": {"type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$", "maxLength": 80}, "destination": {"type": "string", "minLength": 6, "maxLength": 128}, "normalized_transaction_hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"}, "replay_nonce": {"type": "string", "minLength": 8, "maxLength": 128}}},
    "error": {"type": "object", "additionalProperties": false, "required": ["code", "message"], "properties": {"code": {"type": "string", "minLength": 3, "maxLength": 80}, "message": {"type": "string", "minLength": 3, "maxLength": 300}}},
    "signing": {"type": "object", "additionalProperties": false, "required": ["algorithm", "key_id", "signature"], "properties": {"algorithm": {"type": "string", "minLength": 3, "maxLength": 64}, "key_id": {"type": "string", "minLength": 3, "maxLength": 128}, "signature": {"type": ["string", "null"], "maxLength": 512}}}
  }
}
