{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wiredchaos.dev/schemas/sovereignty/model.schema.json",
  "title": "Sovereignty model registry record",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "status", "providerId", "rightsId", "capabilities", "operations", "costUsd", "latencyMs", "notes"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "status": { "enum": ["mock", "development_only", "not_verified", "active", "disabled", "quarantined"] },
    "providerId": { "type": "string", "minLength": 1 },
    "rightsId": { "type": "string", "minLength": 1 },
    "hardwareId": { "type": "string", "minLength": 1 },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "enum": ["chat", "embedding", "tool_plan", "deterministic_fallback"] }
    },
    "operations": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "enum": ["inference", "evaluation", "stress_test"] }
    },
    "costUsd": { "oneOf": [{ "type": "number", "minimum": 0 }, { "enum": ["unknown", "not_verified"] }] },
    "latencyMs": { "oneOf": [{ "type": "number", "minimum": 0 }, { "enum": ["unknown", "not_verified"] }] },
    "notes": { "type": "string", "minLength": 1 }
  }
}
