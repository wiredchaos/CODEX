{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentropolis.example/schemas/import-plan.schema.json",
  "title": "AGENTROPOLIS Import Plan",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "target", "sourceRepository", "runtime"],
  "properties": {
    "schemaVersion": { "type": "string", "const": "1.0.0" },
    "target": { "type": "string", "minLength": 3, "maxLength": 160 },
    "sourceRepository": { "type": "string", "minLength": 3, "maxLength": 240 },
    "runtime": { "type": "string", "minLength": 2, "maxLength": 80 },
    "notes": { "type": "string", "maxLength": 1000 }
  }
}
