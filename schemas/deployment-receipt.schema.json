{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentropolis.example/schemas/deployment-receipt.schema.json",
  "title": "AGENTROPOLIS Deployment Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "deploymentId",
    "environment",
    "target",
    "sourceRepository",
    "sourceCommit",
    "runtime",
    "validation",
    "rollback",
    "createdAt"
  ],
  "properties": {
    "schemaVersion": { "type": "string", "const": "1.0.0" },
    "deploymentId": { "type": "string", "pattern": "^[a-z0-9][a-z0-9.-]{2,120}$" },
    "environment": { "type": "string", "enum": ["preview", "staging", "production"] },
    "target": { "type": "string", "minLength": 3, "maxLength": 160 },
    "sourceRepository": { "type": "string", "minLength": 3, "maxLength": 240 },
    "sourceCommit": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
    "runtime": { "type": "string", "minLength": 2, "maxLength": 80 },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "healthChecks"],
      "properties": {
        "status": { "type": "string", "enum": ["pending", "passed", "failed"] },
        "healthChecks": {
          "type": "array",
          "items": { "$ref": "#/$defs/healthCheck" },
          "default": []
        },
        "evidence": { "type": "array", "items": { "type": "string", "minLength": 1 }, "default": [] }
      }
    },
    "rollback": {
      "type": "object",
      "additionalProperties": false,
      "required": ["available", "reference"],
      "properties": {
        "available": { "type": "boolean" },
        "reference": { "type": "string" }
      }
    },
    "createdAt": { "type": "string", "format": "date-time" },
    "notes": { "type": "string", "maxLength": 1000 }
  },
  "$defs": {
    "healthCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "status", "checkedAt"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 120 },
        "status": { "type": "string", "enum": ["passed", "failed", "skipped"] },
        "checkedAt": { "type": "string", "format": "date-time" },
        "evidence": { "type": "string", "maxLength": 240 }
      }
    }
  }
}
