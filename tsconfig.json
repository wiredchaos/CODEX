{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "rootDir": ".",
    "types": [
      "node"
    ],
    "paths": {
      "@kdao/*": [
        "packages/*/src"
      ]
    },
    "baseUrl": "."
  },
  "include": [
    "apps/**/*.ts",
    "packages/**/*.ts",
    "prisma/**/*.ts",
    "tests/**/*.ts",
    "eslint.config.js"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "site",
    "wired-chaos-meta",
    "wired-chaos-stack"
  ]
}
